{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "openrouter/auto",
        "fallbacks": [
          "google/gemini-3-flash-preview",
          "google/gemini-2.5-flash",
          "google/gemini-3.1-flash-lite-preview",
          "google/gemini-2.5-flash-lite",
          "google/gemma-4-26b",
          "google/gemma-3-27b",
          "google/gemma-4-31b"
        ]
      },
      "models": {
        "openrouter/nvidia/nemotron-3-super-120b-a12b:free": {},
        "openrouter/openai/gpt-oss-120b:free": {},
        "openrouter/openai/gpt-oss-20b:free": {}
      }
    }
  },
  "models": {
    "providers": {
      "openrouter": {
        "apiKey": "__OPENROUTER_API_KEY__",
        "baseUrl": "",
        "models": []
      },
      "gemini": {
        "apiKey": "__GEMINI_API_KEY__",
        "baseUrl": "",
        "models": []
      }
    }
  },
  "channels": {
      "telegram": {
          "enabled": true,
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "dmPolicy": "open",
          "allowFrom": [],
          "streaming": {
            "mode": "partial",
            "chunkMode": "newline"
          }
      }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": ""
    },
    "port": 18789,
    "bind": "loopback",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "allowInsecureAuth": true
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "coding",
    "web": {
      "search": {
        "provider": "gemini"
      }
    }
  },
  "auth": {
    "profiles": {
      "google:default": {
        "provider": "google",
        "mode": "api_key"
      },
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      }
    }
  },
  "wizard": {
    "lastRunAt": "2026-04-10T01:49:04.529Z",
